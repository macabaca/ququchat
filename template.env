# 必填：数据库与鉴权
DB_USER=
DB_PASSWORD=
AUTH_JWT_SECRET=

# 必填：RabbitMQ
RABBITMQ_USER=
RABBITMQ_PASSWORD=

# 可选：Redis（为空表示无密码）
REDIS_PASSWORD=

# 必填：MinIO（当 storage.provider=minio 时使用）
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=

# 可选：LLM/AIGC/Embedding/Vector
LLM_API_KEY=
AIGC_API_KEY=
EMBEDDING_API_KEY=
VECTOR_API_KEY=

# 可选：OSS（当 storage.provider=oss 时使用）
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_SECURITY_TOKEN=
