{
  "name": "frontend",
  "version": "1.0.4",
  "description": "QuquChat Desktop App",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "electron": "electron .",
    "start": "npm run build && electron .",
    "dist": "npm run build && electron-builder",
    "postinstall": "electron-builder install-app-deps",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "electron": "^38.4.0",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "typescript": "^5.9.3",
    "vite": "^7.2.2"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "@types/react-transition-group": "^4.4.12",
    "antd": "^5.27.6",
    "axios": "^1.12.2",
    "dexie": "^4.2.1",
    "jotai": "^2.15.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.5",
    "react-transition-group": "^4.4.5",
    "sql.js": "^1.14.0",
    "zustand": "^5.0.8"
  },
  "build": {
    "appId": "com.ququchat.app",
    "productName": "QuquChat",
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "database.js",
      "node_modules/sql.js/**",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "zip"
    }
  }
}
